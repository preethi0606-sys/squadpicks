# ─── COPY THIS FILE TO .env AND FILL IN YOUR VALUES ───────────────────────────

# Telegram Bot (from @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here
BOT_USERNAME=squadpicks_bot
BOT_NAME=SquadPicks
MINI_APP_SHORT_NAME=Squadpicks

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# Railway deployment URL (no https://)
RAILWAY_PUBLIC_DOMAIN=your-app.up.railway.app
MINI_APP_URL=https://your-app.up.railway.app
APP_URL=https://your-app.up.railway.app

# Google OAuth  ← NEW
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Authorised redirect URI: https://your-app.up.railway.app/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Session secret — any long random string
SESSION_SECRET=change-me-to-any-random-string-32-chars

# YouTube API
YOUTUBE_API_KEY=your_youtube_api_key_here

# Filmi Craft channel
FILMICRAFT_CHANNEL_ID=UClF9UTljviumfJf7t-VR5tg
FILMICRAFT_CHANNEL_NAME=Filmi Craft

# Admin scrape endpoint protection
ADMIN_SECRET=your_admin_secret_here

# Optional — RapidAPI fallback for streaming data
# RAPIDAPI_KEY=

NODE_ENV=production
