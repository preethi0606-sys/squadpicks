# Copy this file to .env and fill in your values
# Get your bot token from @BotFather on Telegram

BOT_TOKEN=your_telegram_bot_token_here

# Optional: custom path for the picks database file
# DB_PATH=./data/picks.json

# Mini App — set this after Railway deploys (your Railway public domain)
# Example: squadpicks-bot-production.up.railway.app
RAILWAY_PUBLIC_DOMAIN=your-app-name.up.railway.app
MINI_APP_URL=https://your-app-name.up.railway.app
